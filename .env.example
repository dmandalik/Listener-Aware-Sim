# ─────────────────────────────────────────────────────────────────────────────
# Fetch Games — environment
#
# Copy to `.env.local` for dev. NEVER commit real secrets.
# The app FAILS LOUDLY if a required var is missing (see src/lib/config.ts).
# ─────────────────────────────────────────────────────────────────────────────

# Which database driver to use.
#   pglite  — embedded in-process Postgres, data at ./.pglite (local dev/tests, no server)
#   neon    — Neon serverless Postgres (production); requires DATABASE_URL
DB_DRIVER=pglite

# Neon connection string. Required when DB_DRIVER=neon. Ignored for pglite.
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Where PGlite persists its data dir (relative to repo root). Used only for pglite.
PGLITE_DATA_DIR=./.pglite

# ── Admin (see §12: /admin export + dashboard) ───────────────────────────────
# Single shared secret gate for the admin route. No user accounts.
ADMIN_SECRET=change-me-in-prod

# ── Prolific (see §8) ────────────────────────────────────────────────────────
# Completion redirect codes. Kept in env so a new study needs no code change.
PROLIFIC_COMPLETION_CODE=CHANGME_COMPLETE
PROLIFIC_SCREENOUT_CODE=CHANGME_SCREENOUT
